__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# ─── Node.js / Frontend ───────────────────────────────────────────────────
node_modules/
.next/
out/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Environment & Secrets ─────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Database ──────────────────────────────────────────────────────────────
*.db
*.sqlite3

# ─── IDE & OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Build & Coverage ─────────────────────────────────────────────────────
coverage/
htmlcov/
.pytest_cache/
*.tsbuildinfo
next-env.d.ts

# ─── Logs ──────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── Vercel ────────────────────────────────────────────────────────────────
.vercel

